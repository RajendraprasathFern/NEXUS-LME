<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
   <targetConfigs>
    <targetConfig targets="lightning__FlowScreen">
        <property name="recordId" type="String" label="Account ID" role="inputOnly"/>
        <property name="varAppId" type="String" label="Application ID" role="inputOnly"/>
        <!-- These will now show up as Record Collections in Flow -->
        <property name="incomeItems" type="@salesforce/schema/Income__c[]" label="Income List" role="outputOnly"/>
        <property name="assetItems" type="@salesforce/schema/Asset__c[]" label="Asset List" role="outputOnly"/>
        <property name="liabilityItems" type="@salesforce/schema/Liability__c[]" label="Liability List" role="outputOnly"/>
    </targetConfig>
</targetConfigs>
</LightningComponentBundle>